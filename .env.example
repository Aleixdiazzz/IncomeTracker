# Copy to .env.local for local development. Do NOT commit .env.local.
# Only variables prefixed with NEXT_PUBLIC_ are exposed to the browser.

# Postgres connection string. Matches docker-compose.yml defaults.
DATABASE_URL=postgres://incometracker:incometracker@localhost:5432/incometracker

# Secret used by Better Auth to sign session cookies / JWTs.
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Base URL used by Better Auth for callbacks. Match the dev server port.
BETTER_AUTH_URL=http://localhost:3000

# Public base URL exposed to the browser-side Better Auth client.
NEXT_PUBLIC_APP_URL=http://localhost:3000
