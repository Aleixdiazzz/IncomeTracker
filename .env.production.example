# Copy to .env.production ON THE VPS and fill in. Do NOT commit .env.production.
#   cp .env.production.example .env.production && nano .env.production
#
# Compose reads this via: docker compose -f docker-compose.prod.yml --env-file .env.production ...

# --- Postgres (used by the postgres container) ---
POSTGRES_USER=incometracker
POSTGRES_DB=incometracker
# Generate: openssl rand -base64 24   (avoid : / @ to keep the URL below simple)
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# --- App database connection ---
# Host is the compose service name `postgres`, NOT localhost. Must match the
# three POSTGRES_* values above.
DATABASE_URL=postgres://incometracker:CHANGE_ME_STRONG_PASSWORD@postgres:5432/incometracker

# --- Better Auth ---
# Generate a fresh one for production (do not reuse the dev secret):
#   openssl rand -base64 32
BETTER_AUTH_SECRET=CHANGE_ME_ROTATED_SECRET
# Public HTTPS URL the app is served on (your domain/subdomain).
BETTER_AUTH_URL=https://CHANGE_ME.example.com
NEXT_PUBLIC_APP_URL=https://CHANGE_ME.example.com

# --- Local bind port for the reverse proxy to target ---
# Only used by deploy/deploy.sh's curl smoke test. Compose itself no longer
# publishes a host port — Caddy reaches the app over the shared xpose-network.
# Leave at 3000 unless you also change the container's PORT env.
APP_PORT=3000
